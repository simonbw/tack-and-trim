{
  "name": "tack-and-trim",
  "version": "0.1.0",
  "description": "Tack and Trim - A game by Simon",
  "scripts": {
    "start": "NODE_ENV=development rm -rf .parcel-cache && concurrently -n assets,server \"npm run watch-manifest\" \"npm run dev-server\"",
    "dev-server": "tsx ./bin/dev-server.ts",
    "watch-manifest": "tsx ./bin/generate-asset-types.ts -d ./resources watch",
    "build": "parcel build src/index.html && npm run copy-static-assets",
    "copy-static-assets": "mkdir -p dist/assets/levels && cp static/levels/*.terrain static/levels/*.wavemesh static/levels/*.windmesh static/levels/*.trees dist/assets/levels/ 2>/dev/null || true",
    "tsc": "tsc --noEmit",
    "tsc-watch": "tsc --noEmit --watch",
    "tsgo": "tsgo --noEmit",
    "tsgo-watch": "tsgo --noEmit --watch",
    "prettier": "prettier --write src",
    "generate-manifest": "tsx ./bin/generate-asset-types.ts -d ./resources",
    "test": "playwright test",
    "benchmark": "playwright test --config playwright.benchmark.config.ts",
    "build-wavemesh": "cargo build --release --manifest-path pipeline/Cargo.toml -p wavemesh-builder && ./pipeline/target/release/wavemesh-builder",
    "build-wavemesh:compile": "cargo build --release --manifest-path pipeline/Cargo.toml -p wavemesh-builder",
    "build-level": "cargo build --release --manifest-path pipeline/Cargo.toml -p build-level && ./pipeline/target/release/build-level",
    "profile-wavemesh:samply": "./pipeline/profile-samply.sh -p wavemesh-builder",
    "profile-wavemesh:samply-view": "samply load pipeline/profile-samply.json",
    "profile-terrain:samply": "./pipeline/profile-samply.sh -p build-level",
    "download-terrain": "./bin/build-level download",
    "build-terrain-grid": "./bin/build-level build-grid",
    "extract-terrain-contours": "./bin/build-level extract",
    "validate-level": "./bin/build-level validate",
    "build-terrain": "./bin/build-level build",
    "import-terrain": "./bin/build-level build",
    "docs": "typedoc",
    "count-tokens": "tsx ./bin/count-tokens.ts",
    "test:terrain-gpu": "npx tsx tests/terrain-gpu-test.ts"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/simonbw/tack-and-trim.git"
  },
  "author": "",
  "license": "UNLICENSED",
  "homepage": "https://github.com/simonbw/tack-and-trim#readme",
  "dependencies": {
    "preact": "^10.28.2",
    "simplex-noise": "^4.0.3"
  },
  "alias": {
    "react": "preact/compat",
    "react-dom": "preact/compat",
    "react-dom/client": "preact/compat/client",
    "react/jsx-runtime": "preact/jsx-runtime",
    "preact/jsx-dev-runtime": "preact/jsx-runtime"
  },
  "devDependencies": {
    "@anthropic-ai/sdk": "^0.32.1",
    "@parcel/macros": "^2.16.3",
    "@parcel/reporter-bundle-analyzer": "^2.16.3",
    "@parcel/resolver-glob": "^2.16.3",
    "@parcel/transformer-typescript-tsc": "^2.16.3",
    "@playwright/test": "^1.57.0",
    "@types/http-proxy": "^1.17.17",
    "@types/node": "^24.0.4",
    "@types/yargs": "^17.0.32",
    "@typescript/native-preview": "^7.0.0-dev.20260109.1",
    "@webgpu/types": "^0.1.68",
    "assert": "^2.1.0",
    "camelcase": "^8.0.0",
    "chokidar": "^4.0.3",
    "concurrently": "^9.2.0",
    "console-browserify": "^1.2.0",
    "geotiff": "^2.1.4-beta.1",
    "glob": "^11.0.3",
    "http-proxy": "^1.18.1",
    "parcel": "^2.16.3",
    "prettier": "^3.6.0",
    "process": "^0.11.10",
    "refactor-ts": "github:simonbw/refactor-ts",
    "tsx": "^4.20.3",
    "typedoc": "^0.28.16",
    "typescript": "^5.9.3",
    "util": "^0.12.5",
    "webgpu": "^0.3.8",
    "yargs": "^18.0.0"
  }
}
