#!/usr/bin/env bash

set -euo pipefail

SOURCE_PATH="${BASH_SOURCE[0]}"
while [[ -L "$SOURCE_PATH" ]]; do
  SOURCE_DIR="$(cd -P -- "$(dirname -- "$SOURCE_PATH")" && pwd)"
  SOURCE_PATH="$(readlink "$SOURCE_PATH")"
  [[ "$SOURCE_PATH" != /* ]] && SOURCE_PATH="$SOURCE_DIR/$SOURCE_PATH"
done

SCRIPT_DIR="$(cd -P -- "$(dirname -- "$SOURCE_PATH")" && pwd)"
REPO_ROOT="$(cd -- "$SCRIPT_DIR/.." && pwd)"

list_regions() {
  # Delegate to Rust CLI for accurate listing (scans level files for region field)
  cargo run --release --manifest-path "$REPO_ROOT/pipeline/Cargo.toml" -p build-level -- list-regions 2>/dev/null
}

list_levels() {
  local levels_dir="$REPO_ROOT/resources/levels"
  if [[ ! -d "$levels_dir" ]]; then
    return 0
  fi
  for f in "$levels_dir"/*.level.json; do
    if [[ -f "$f" ]]; then
      basename "$f" .level.json
    fi
  done | sort
}

print_help() {
  cat <<'EOF'
Usage:
  build-level [--level <name>]                    Run full pipeline + mesh build (all if omitted)
  build-level build [--level <name>]              Run full pipeline + mesh build (all if omitted)
  build-level wave-mesh [--level <name>]          Build wave mesh(es) (all if omitted)
  build-level wind-mesh [--level <name>]          Build wind mesh(es) (all if omitted)
  build-level tide-mesh [--level <name>]          Build tide mesh(es) (all if omitted)
  build-level trees [--level <name>]              Generate tree positions (all if omitted)
  build-level extract [--level <name>]            Extract terrain (all regions if omitted)
  build-level download [--level <name>]           Download elevation tiles (all regions if omitted)
  build-level build-grid [--level <name>]         Build merged elevation grid (all regions if omitted)
  build-level clean [--level <name>]              Clean generated outputs (all regions if omitted)
  build-level validate [path] [--level <name>]    Validate level/terrain (all levels if omitted)
  build-level list-levels                         List available levels
  build-level list-regions                        List levels with region config
  build-level completion zsh                      Print zsh completion script

Examples:
  build-level
  build-level --level vendovi-island
  build-level build --level san-juan-islands
  build-level wave-mesh --level default
  build-level validate --level san-juan-islands
  eval "$(build-level completion zsh)"
EOF
}

print_zsh_completion() {
  cat <<'EOF'
#compdef build-level

_build_level_levels() {
  local -a levels
  levels=(${(f)"$(build-level list-levels 2>/dev/null)"})
  if (( ${#levels[@]} > 0 )); then
    compadd -- "${levels[@]}"
  fi
}

_build_level() {
  local cmd="${words[2]-}"

  if [[ -z "$cmd" ]]; then
    _values 'subcommand' \
      'build[Run full pipeline]' \
      'wave-mesh[Build .wavemesh files only]' \
      'wind-mesh[Build .windmesh files only]' \
      'tide-mesh[Build .tidemesh files only]' \
      'download[Download terrain tiles]' \
      'build-grid[Build merged terrain grid cache]' \
      'extract[Extract terrain contours]' \
      'clean[Delete generated outputs while keeping downloaded tiles]' \
      'validate[Validate level/terrain contour topology]' \
      'list-levels[List available level slugs]' \
      'list-regions[List available region slugs]' \
      'completion[Print shell completion script]'
    return
  fi

  case "$cmd" in
    build|download|extract|import|clean)
      _arguments \
        '--level[Level name]:level:_build_level_levels' \
        '-h[Show help]' \
        '--help[Show help]'
      ;;
    build-grid)
      _arguments \
        '--level[Level name]:level:_build_level_levels' \
        '--force[Rebuild cached grid even if already present]' \
        '-h[Show help]' \
        '--help[Show help]'
      ;;
    wave-mesh|wind-mesh|tide-mesh|trees)
      _arguments \
        '--level[Level name]:level:_build_level_levels' \
        '-h[Show help]' \
        '--help[Show help]'
      ;;
    validate)
      _arguments \
        '--level[Level name]:level:_build_level_levels' \
        '-h[Show help]' \
        '--help[Show help]' \
        '*:level file:_files -g "*.{level,terrain}.json"'
      ;;
    completion)
      _arguments '1:shell:(zsh)'
      ;;
    list-levels|list-regions)
      ;;
    *)
      _arguments \
        '--level[Level name]:level:_build_level_levels' \
        '-h[Show help]' \
        '--help[Show help]'
      ;;
  esac
}

compdef _build_level build-level
EOF
}

run_rust_cli() {
  exec cargo run \
    --release \
    --manifest-path "$REPO_ROOT/pipeline/Cargo.toml" \
    -p build-level \
    -- \
    "$@"
}

case "${1:-}" in
  "" )
    run_rust_cli
    ;;
  -h|--help|help )
    print_help
    ;;
  list-levels )
    if [[ $# -gt 1 ]]; then
      echo "list-levels does not accept arguments" >&2
      exit 2
    fi
    list_levels
    ;;
  list-regions )
    if [[ $# -gt 1 ]]; then
      echo "list-regions does not accept arguments" >&2
      exit 2
    fi
    list_regions
    ;;
  completion )
    if [[ "${2:-}" == "zsh" ]]; then
      print_zsh_completion
      exit 0
    fi
    echo "Usage: build-level completion zsh" >&2
    exit 2
    ;;
  build|wave-mesh|wind-mesh|tide-mesh|trees|download|build-grid|extract|clean|validate|import )
    run_rust_cli "$@"
    ;;
  --* )
    run_rust_cli "$@"
    ;;
  * )
    # Shorthand: build-level <level-slug> → build --level <slug>
    run_rust_cli build --level "$1" "${@:2}"
    ;;
esac
