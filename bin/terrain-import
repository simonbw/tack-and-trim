#!/usr/bin/env bash

set -euo pipefail

SOURCE_PATH="${BASH_SOURCE[0]}"
while [[ -L "$SOURCE_PATH" ]]; do
  SOURCE_DIR="$(cd -P -- "$(dirname -- "$SOURCE_PATH")" && pwd)"
  SOURCE_PATH="$(readlink "$SOURCE_PATH")"
  [[ "$SOURCE_PATH" != /* ]] && SOURCE_PATH="$SOURCE_DIR/$SOURCE_PATH"
done

SCRIPT_DIR="$(cd -P -- "$(dirname -- "$SOURCE_PATH")" && pwd)"
REPO_ROOT="$(cd -- "$SCRIPT_DIR/.." && pwd)"

list_regions() {
  local root="$REPO_ROOT/assets/terrain"
  local region_json

  if [[ ! -d "$root" ]]; then
    return 0
  fi

  for region_json in "$root"/*/region.json; do
    if [[ -f "$region_json" ]]; then
      basename "$(dirname "$region_json")"
    fi
  done | sort
}

print_help() {
  cat <<'EOF'
Usage:
  terrain-import [import] [--region <slug>]
  terrain-import <download|build-grid|extract|validate|import> [args]
  terrain-import list-regions
  terrain-import completion zsh

Examples:
  terrain-import --region san-juan-islands
  terrain-import build-grid --region san-juan-islands --force
  terrain-import validate --region san-juan-islands
  terrain-import list-regions
  eval "$(terrain-import completion zsh)"
EOF
}

print_zsh_completion() {
  cat <<'EOF'
#compdef terrain-import

_terrain_import_regions() {
  local -a regions
  regions=(${(f)"$(terrain-import list-regions 2>/dev/null)"})
  if (( ${#regions[@]} > 0 )); then
    compadd -- "${regions[@]}"
  fi
}

_terrain_import() {
  local cmd="${words[2]-}"

  if [[ -z "$cmd" ]]; then
    _values 'subcommand' \
      'import[Run full pipeline]' \
      'download[Download terrain tiles]' \
      'build-grid[Build merged terrain grid cache]' \
      'extract[Extract contour rings]' \
      'validate[Validate level contour topology]' \
      'list-regions[List available region slugs]' \
      'completion[Print shell completion script]'
    return
  fi

  if [[ "$cmd" == "--region" || "$cmd" == "-h" || "$cmd" == "--help" ]]; then
    _arguments \
      '--region[Region slug]:region:_terrain_import_regions' \
      '-h[Show help]' \
      '--help[Show help]'
    return
  fi

  case "$cmd" in
    download|extract|import)
      _arguments \
        '--region[Region slug]:region:_terrain_import_regions' \
        '-h[Show help]' \
        '--help[Show help]'
      ;;
    build-grid)
      _arguments \
        '--region[Region slug]:region:_terrain_import_regions' \
        '--force[Rebuild cached grid even if already present]' \
        '-h[Show help]' \
        '--help[Show help]'
      ;;
    validate)
      _arguments \
        '--region[Region slug]:region:_terrain_import_regions' \
        '-h[Show help]' \
        '--help[Show help]' \
        '*:level file:_files -g "*.level.json"'
      ;;
    completion)
      _arguments '1:shell:(zsh)'
      ;;
    list-regions)
      ;;
    *)
      # Default invocation mode (no explicit subcommand): treat as import args.
      _arguments \
        '--region[Region slug]:region:_terrain_import_regions' \
        '-h[Show help]' \
        '--help[Show help]'
      ;;
  esac
}

compdef _terrain_import terrain-import
EOF
}

run_rust_cli() {
  exec cargo run \
    --manifest-path "$REPO_ROOT/pipeline/Cargo.toml" \
    -p terrain-import \
    -- \
    "$@"
}

case "${1:-}" in
  "" )
    run_rust_cli import
    ;;
  -h|--help|help )
    print_help
    ;;
  list-regions )
    if [[ $# -gt 1 ]]; then
      echo "list-regions does not accept arguments" >&2
      exit 2
    fi
    list_regions
    ;;
  completion )
    if [[ "${2:-}" == "zsh" ]]; then
      print_zsh_completion
      exit 0
    fi
    echo "Usage: terrain-import completion zsh" >&2
    exit 2
    ;;
  download|build-grid|extract|validate|import )
    run_rust_cli "$@"
    ;;
  --* )
    run_rust_cli import "$@"
    ;;
  * )
    # Shorthand: terrain-import <region-slug>
    run_rust_cli import --region "$1" "${@:2}"
    ;;
esac
